{
  "entities": {
    "Profile": {
      "title": "UserProfile",
      "description": "User profile document associated with their authentication UID.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique user identifier matching the auth UID." },
        "email": { "type": "string", "format": "email", "description": "User email address." },
        "fullName": { "type": "string", "description": "User's full name." },
        "avatarUrl": { "type": "string", "description": "User avatar image URL." },
        "phone": { "type": "string", "description": "User phone number." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Address": {
      "title": "Address",
      "description": "Shipping or billing address for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "streetAddress": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "postalCode": { "type": "string" },
        "country": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "streetAddress", "city", "country"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "An item saved to the user's wishlist.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "productId"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "An item saved to the user's shopping cart.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "productId", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Packaging", "Out for Delivery", "Delivered", "Cancelled"] },
        "shippingAddress": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["Pending", "Verified", "Failed", "Refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "totalAmount", "status", "shippingAddress", "paymentMethod", "paymentStatus"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "A single line item in an order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "integer" }
      },
      "required": ["id", "orderId", "productId", "productName", "price", "quantity"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review of a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "productId", "rating"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon code.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountPercent": { "type": "integer" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "discountPercent", "active"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "read"]
    }
  },
  "firestore": {
    "profiles/{userId}": {
      "schema": "Profile",
      "description": "The user profile document."
    },
    "addresses/{addressId}": {
      "schema": "Address",
      "description": "User shipping address documents."
    },
    "wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User wishlist item documents."
    },
    "cart/{cartId}": {
      "schema": "CartItem",
      "description": "User cart item documents."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Order records."
    },
    "orders/{orderId}/items/{itemId}": {
      "schema": "OrderItem",
      "description": "Individual items in an order."
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupon definitions."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app notifications."
    }
  }
}
